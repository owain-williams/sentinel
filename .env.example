# =============================================================================
# Sentinel — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Never commit .env to git.

# ---------------------------------------------------------------------------
# Phase 1 — Data Connectors
# ---------------------------------------------------------------------------

# Finnhub (options data, WebSocket + REST)
# Register free: https://finnhub.io/register
FINNHUB_API_KEY=

# FRED (macro data)
# Register free: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# GDELT — no API key required

# ---------------------------------------------------------------------------
# Phase 2 — Additional Connectors
# ---------------------------------------------------------------------------

# ADS-B Exchange (military flight tracking)
# Register free: https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSB_RAPIDAPI_KEY=

# Quiver Quantitative (congressional trading)
# Register: https://www.quiverquant.com/
QUIVER_API_TOKEN=

# Polymarket — no API key required (read-only data)

# ---------------------------------------------------------------------------
# Phase 2 — Execution
# ---------------------------------------------------------------------------

# IG Markets (spread betting)
# Apply: https://labs.ig.com/
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Phase 3 — Prediction Markets
# ---------------------------------------------------------------------------

# Betfair Exchange
# Apply: https://developer.betfair.com/
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_PATH=
BETFAIR_KEY_PATH=

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------

# Telegram Bot
# Create via @BotFather: https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
DATABASE_PATH=./data/sentinel.db
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Risk Parameters
# ---------------------------------------------------------------------------
MAX_OPEN_POSITIONS=5
MAX_DAILY_RISK_PCT=0.10
RISK_PER_TRADE_PCT=0.03
CIRCUIT_BREAKER_DAILY_LOSS_PCT=0.05
